PORT=4000
NODE_ENV=development

# ─── Base de datos (Supabase PostgreSQL) ──────────────────────────────────
# Modo pooler transaccional (para la app en producción con pgBouncer)
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"

# Modo directo (para migraciones Prisma — sin pgBouncer)
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-0-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require"

# ─── Supabase Storage ─────────────────────────────────────────────────────
# Supabase → Settings → API
SUPABASE_URL="https://<project-ref>.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="<service-role-key>"

# ─── JWT ──────────────────────────────────────────────────────────────────
JWT_SECRET="cambia-esto-en-produccion"
JWT_EXPIRES_IN="8h"

# ─── CORS (solo en desarrollo) ────────────────────────────────────────────
CORS_ORIGIN="http://localhost:5173"
